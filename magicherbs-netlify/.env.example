# Локальная разработка (необязательно указывать — по умолчанию используется
# локальный файл db/magicherbs.db, работает "из коробки")
PORT=3000

# --- Turso (облачная БД для продакшна на Netlify) ---
# Получить: 1) npm i -g @turso/cli  (или см. https://docs.turso.tech/cli/installation)
#           2) turso auth signup / login
#           3) turso db create magicherbs
#           4) turso db show magicherbs --url        -> TURSO_DATABASE_URL
#           5) turso db tokens create magicherbs      -> TURSO_AUTH_TOKEN
# Если оставить пустыми — код автоматически работает с локальным файлом SQLite.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Токен вашего Telegram-бота (BotFather -> /mybots -> ваш бот -> API Token).
# Нужен для проверки подлинности Telegram.WebApp.initData.
# Без него проверка подписи отключается (годится только для разработки).
TELEGRAM_BOT_TOKEN=
